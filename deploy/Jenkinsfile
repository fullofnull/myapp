pipeline {
  agent {
    kubernetes {
      yaml """
        apiVersion: v1
        kind: Pod
        spec:
          nodeSelector:
            usage: infra
          containers:
          - name: gradle
            image: 192.168.241.101:30002/proxy-cache/gradle:9.4.1-jdk21
            command: ['sleep', 'infinity']
            resources:
              requests:
                memory: "512Mi"
                cpu: "500m"
              limits:
                memory: "1Gi"
                cpu: "1"
          - name: kaniko
            image: 192.168.241.101:30002/proxy-cache/martizih/kaniko:debug
            command: ['sleep', 'infinity']
            volumeMounts:
            - name: harbor-creds
              mountPath: /kaniko/.docker
          volumes:
          - name: harbor-creds
            secret:
              secretName: harbor-credentials
              items:
              - key: .dockerconfigjson
                path: config.json
      """
    }
  }

  environment {
    HARBOR_URL  = '192.168.241.101:30002'
    IMAGE_NAME  = 'base/spring-app'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Build') {
      steps {
        container('gradle') {
          sh 'gradle clean build -x test'
        }
      }
    }

    stage('Image Build & Push') {
      steps {
        container('kaniko') {
          sh """
        /kaniko/executor \
          --context=dir://${WORKSPACE} \
          --dockerfile=${WORKSPACE}/deploy/Dockerfile \
          --destination=${HARBOR_URL}/${IMAGE_NAME}:${BUILD_NUMBER} \
          --destination=${HARBOR_URL}/${IMAGE_NAME}:latest \
          --insecure \
          --insecure-registry=${HARBOR_URL} \
          --skip-tls-verify
      """
        }
      }
    }

    stage('Update Manifest') {
      steps {
        container('gradle') {
          withCredentials([usernamePassword(
            credentialsId: 'github-credentials',
            usernameVariable: 'GIT_USER',
            passwordVariable: 'GIT_TOKEN'
          )]) {
            sh """
              # 1. 워크스페이스 위치로 명확하게 이동
              cd ${WORKSPACE}

              # 2. Git 사용자 설정
              git config user.email "jenkins@ci.local"
              git config user.name "Jenkins"

              # 3. sed 명령어 수정 (역슬래시 제거 및 유연한 매칭)
              # deployment.yaml에서 image: 부분이 어떤 주소든 상관없이 현재 빌드 번호로 교체합니다.
              sed -i "s|image: .*/${IMAGE_NAME}:.*|\
              image: ${HARBOR_URL}/${IMAGE_NAME}:${BUILD_NUMBER}|" \
              deploy/deployment.yaml

              # 4. 변경사항 확인 및 푸시
              git add deploy/deployment.yaml

              # 변경사항이 있을 때만 커밋 (에러 방지)
              if ! git diff --cached --exit-code --quiet; then
                git commit -m "ci: update image tag to ${BUILD_NUMBER}"
                git push https://${GIT_USER}:${GIT_TOKEN}@github.com/fullofnull/myapp.git HEAD:main
              else
                echo "변경사항이 없어 커밋을 건너뜁니다."
              fi
            """
          }
        }
      }
    }
  }

  post {
    success {
      echo "빌드 성공: \${IMAGE_NAME}:\${BUILD_NUMBER}"
    }
    failure {
      echo '빌드 실패'
    }
  }
}
