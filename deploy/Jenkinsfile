pipeline {
  agent {
    kubernetes {
      yaml """
        apiVersion: v1
        kind: Pod
        spec:
          hostAliases:
          - ip: "192.168.241.101"
            hostnames:
            - "my-harbor.local"
          nodeSelector:
            usage: infra
          containers:
          - name: gradle
            image: 192.168.241.101:30002/proxy-cache/gradle:9.4.1-jdk21
            command: ['sleep', 'infinity']
            resources:
              requests:
                memory: "512Mi"
                cpu: "500m"
              limits:
                memory: "1Gi"
                cpu: "1"
          - name: kaniko
            image: 192.168.241.101:30002/proxy-cache/martizih/kaniko:debug
            command: ['sleep', 'infinity']
            volumeMounts:
            - name: harbor-creds
              mountPath: /kaniko/.docker
          volumes:
          - name: harbor-creds
            secret:
              secretName: harbor-credentials
              items:
              - key: .dockerconfigjson
                path: config.json
      """
    }
  }

  environment {
    HARBOR_URL  = 'my-harbor.local:30002'
    IMAGE_NAME  = 'base/spring-app'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Build') {
      steps {
        container('gradle') {
          sh 'gradle clean build -x test'
        }
      }
    }

    stage('Image Build & Push') {
      steps {
        container('kaniko') {
          sh """
        /kaniko/executor \
          --context=dir://${WORKSPACE} \
          --dockerfile=${WORKSPACE}/deploy/Dockerfile \
          --destination=${HARBOR_URL}/${IMAGE_NAME}:${BUILD_NUMBER} \
          --destination=${HARBOR_URL}/${IMAGE_NAME}:latest \
          --insecure \
          --insecure-registry=${HARBOR_URL} \
          --skip-tls-verify
      """
        }
      }
    }

    stage('Update Manifest') {
      steps {
        container('gradle') {
          withCredentials([usernamePassword(
            credentialsId: 'github-credentials',
            usernameVariable: 'GIT_USER',
            passwordVariable: 'GIT_TOKEN'
          )]) {
            sh """
              # 1. 오타 수정 (Q 제거) 및 안전 디렉토리 설정
              cd ${WORKSPACE}
              git config --global --add safe.directory ${WORKSPACE}

              # 2. Git 설정 (따옴표 안의 변수는 \ 없이 사용)
              git config user.email "fullofnull@gmail.com"
              git config user.name "fullofnull"

              # 3. sed 명령어 (이미지 태그 업데이트)
              # 여기서 ${HARBOR_URL} 등은 젠킨스 환경변수를 그대로 사용합니다.
              sed -i "s|image: .*/${IMAGE_NAME}:.*|image: ${HARBOR_URL}/${IMAGE_NAME}:${BUILD_NUMBER}|" deploy/deployment.yaml

              # 4. 충돌 방지 및 푸시
              git add deploy/deployment.yaml
              if ! git diff --cached --exit-code --quiet; then
                git commit -m "ci: update image tag to ${BUILD_NUMBER}"
                git pull origin main --rebase
                git push https://${GIT_USER}:${GIT_TOKEN}@github.com/fullofnull/myapp.git HEAD:main
              fi
            """
          }
        }
      }
    }
  }

  post {
    success {
      echo "빌드 성공: \${IMAGE_NAME}:\${BUILD_NUMBER}"
    }
    failure {
      echo '빌드 실패'
    }
  }
}
