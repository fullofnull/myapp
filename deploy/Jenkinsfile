5. ArgoCD NodePort 충돌 수정
bashkubectl patch svc argocd-server -n argocd -p '{
  "spec": {
    "type": "NodePort",
    "ports": [
      {"name": "http",  "port": 80,  "targetPort": 8080, "nodePort": 30081},
      {"name": "https", "port": 443, "targetPort": 8080, "nodePort": 30443}
    ]
  }
}'

6. worker-node-1에서 Docker 제거
bash# worker-node-1 SSH 접속
vagrant ssh worker-node-1

# Docker 제거
sudo systemctl stop docker
sudo dnf remove -y docker-ce docker-ce-cli
sudo rm -rf /etc/docker

# containerd 설정 복구 (Docker가 덮어썼을 수 있음)
sudo sed -i 's|config_path = ""|config_path = "/etc/containerd/certs.d"|' \
  /etc/containerd/config.toml
sudo systemctl restart containerd

