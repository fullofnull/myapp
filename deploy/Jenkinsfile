그러면 Jenkinsfile도 deploy 폴더에 넣고, Kaniko context와 Dockerfile 경로도 맞게 수정해야 해요:
groovystage('Image Build & Push') {
  steps {
    container('kaniko') {
      sh """
        /kaniko/executor \\
          --context=dir://\${WORKSPACE} \\
          --dockerfile=\${WORKSPACE}/deploy/Dockerfile \\
          --destination=\${HARBOR_URL}/\${IMAGE_NAME}:\${BUILD_NUMBER} \\
          --destination=\${HARBOR_URL}/\${IMAGE_NAME}:latest \\
          --insecure \\
          --skip-tls-verify
      """
    }
  }
}
