파이프라인 테스트 스크립트 수정해서 다시 돌려볼게요:
groovypipeline {
  agent {
    kubernetes {
      yaml """
        apiVersion: v1
        kind: Pod
        spec:
          containers:
          - name: gradle
            image: 192.168.241.101:30002/proxy-cache/gradle:9.4.1-jdk21
            command: ['sleep', 'infinity']
          - name: kaniko
            image: 192.168.241.101:30002/proxy-cache/bitnami/kaniko:latest
            command: ['sleep', 'infinity']
      """
    }
  }
  stages {
    stage('Test') {
      steps {
        container('gradle') {
          sh 'gradle --version'
        }
        container('kaniko') {
          sh '/kaniko/executor version'
        }
      }
    }
  }
}
