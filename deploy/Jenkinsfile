pipeline {
  agent {
    kubernetes {
      yaml """
apiVersion: v1
kind: Pod
spec:
  nodeSelector:
    usage: infra
  hostAliases:
  - ip: "192.168.241.101"
    hostnames:
    - "my-harbor.local"
  containers:
  - name: gradle
    image: 192.168.241.101:30002/proxy-cache/gradle:9.4.1-jdk21
    command: ['sleep', 'infinity']
    resources:
      requests:
        memory: "512Mi"
        cpu: "500m"
      limits:
        memory: "1Gi"
        cpu: "1"
  - name: kaniko
    image: 192.168.241.101:30002/proxy-cache/martizih/kaniko:debug
    command: ['sleep', 'infinity']
    volumeMounts:
    - name: harbor-creds
      mountPath: /kaniko/.docker
    - name: workspace-volume
      mountPath: /home/jenkins/agent
  volumes:
  - name: harbor-creds
    secret:
      secretName: harbor-credentials
      items:
      - key: .dockerconfigjson
        path: config.json
  - name: workspace-volume
    emptyDir: {}
"""
    }
  }

  environment {
    // 중요: Kaniko의 사설 IP 체크 우회를 위해 도메인 이름을 사용합니다.
    HARBOR_URL = 'my-harbor.local:30002'
    IMAGE_NAME = 'base/spring-app'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Build') {
      steps {
        container('gradle') {
          sh 'gradle clean build -x test'
        }
      }
    }

    stage('Image Build & Push') {
      steps {
        container('kaniko') {
          // GODEBUG 변수는 네트워크 라이브러리의 엄격한 체크를 완화하는 데 도움을 줍니다.
          withEnv(['GODEBUG=http2client=0']) {
            sh """
            /kaniko/executor \
            --context=dir://${WORKSPACE} \
            --dockerfile=${WORKSPACE}/deploy/Dockerfile \
            --destination=${HARBOR_URL}/${IMAGE_NAME}:${BUILD_NUMBER} \
            --destination=${HARBOR_URL}/${IMAGE_NAME}:latest \
            --insecure \
            --insecure-registry=${HARBOR_URL} \
            --skip-tls-verify
            """
          }
        }
      }
    }

    stage('Update Manifest') {
      steps {
        container('gradle') {
          withCredentials([usernamePassword(
            credentialsId: 'github-credentials',
            usernameVariable: 'GIT_USER',
            passwordVariable: 'GIT_TOKEN'
          )]) {
            sh """
              git config user.email "jenkins@ci.local"
              git config user.name "Jenkins"
              # 매니페스트 업데이트 시에도 HARBOR_URL 변수를 그대로 활용합니다.
              sed -i 's|image: .*/${IMAGE_NAME}:.*|image: ${HARBOR_URL}/${IMAGE_NAME}:${BUILD_NUMBER}|' deploy/deployment.yaml
              git add deploy/deployment.yaml
              git commit -m "ci: update image tag to ${BUILD_NUMBER}"
              git push https://${GIT_USER}:${GIT_TOKEN}@github.com/fullofnull/myapp.git HEAD:main
            """
          }
        }
      }
    }
  }

  post {
    success {
      echo "빌드 및 푸시 성공: ${HARBOR_URL}/${IMAGE_NAME}:${BUILD_NUMBER}"
    }
    failure {
      echo "빌드 실패"
    }
  }
}