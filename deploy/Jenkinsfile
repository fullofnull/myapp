Jenkins에서 New Item → Pipeline 으로 하나 만들고 아래 스크립트 붙여넣기 해보세요.
groovypipeline {
  agent {
    kubernetes {
      yaml """
        apiVersion: v1
        kind: Pod
        spec:
          containers:
          - name: gradle
            image: 192.168.241.101:30002/proxy-cache/gradle:8.7.2-jdk21
            command: ['sleep', 'infinity']
          - name: kaniko
            image: 192.168.241.101:30002/proxy-cache/kaniko-project/executor:debug
            command: ['sleep', 'infinity']
      """
    }
  }
  stages {
    stage('Test') {
      steps {
        container('gradle') {
          sh 'gradle --version'
        }
      }
    }
  }
}
